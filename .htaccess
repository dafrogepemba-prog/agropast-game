# ============================================================
# .htaccess — RACINE FTP /
# Hébergement LWS mutualisé partagé
# ============================================================

RewriteEngine On

# --- Forcer HTTPS -------------------------------------------
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# --- Fichiers spéciaux : ne pas rediriger ------------------
# ads.txt, robots.txt, sitemap.xml → servis depuis la racine
RewriteCond %{HTTP_HOST} ^(www\.)?agropast-game\.online$ [NC]
RewriteCond %{REQUEST_URI} ^/(ads\.txt|robots\.txt|sitemap\.xml)$
RewriteRule ^ - [L]

# --- API et Admin : pas de redirection ---------------------
RewriteCond %{HTTP_HOST} ^(www\.)?agropast-game\.online$ [NC]
RewriteCond %{REQUEST_URI} !^/agropast-game\.online/
RewriteCond %{REQUEST_URI} ^/(api|admin)/
RewriteRule ^ - [L]

# --- Routage agropast-game.online -------------------------
RewriteCond %{HTTP_HOST} ^(www\.)?agropast-game\.online$ [NC]
RewriteCond %{REQUEST_URI} !^/agropast-game\.online/
RewriteCond %{REQUEST_URI} !^/api/
RewriteCond %{REQUEST_URI} !^/admin/
RewriteRule ^(.*)$ /agropast-game.online/$1 [L]
